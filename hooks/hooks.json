{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Grep|Glob|Write|Edit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/meeting_auto_approve.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/meeting_timestamp.py\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
